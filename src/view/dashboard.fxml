<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.DashboardController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #ede7f6;">

    <!-- LEFT SIDEBAR -->
    <VBox prefWidth="230"
          style="-fx-background-color: #220441; -fx-padding: 0;">

        <!-- Profile Section -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-padding: 28 16 22 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="👤" style="-fx-font-size: 40px; -fx-text-fill: white;"/>
            <Label fx:id="studentNameLabel" text="Student"
                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Label fx:id="studentEmailLabel" text=""
                   style="-fx-text-fill: #c084fc; -fx-font-size: 12px;"
                   wrapText="true" maxWidth="190" alignment="CENTER"/>
        </VBox>

        <!-- Nav Buttons -->
        <VBox spacing="4" style="-fx-padding: 16 12;">

            <Button text="🏠  Home" onAction="#goHome" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <!-- My Tasks active -->
            <Button text="✅  My Tasks" onAction="#openTasks" maxWidth="Infinity"
                    style="-fx-background-color: #581c87; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;
                           -fx-border-color: #a855f7; -fx-border-width: 0 0 0 3;
                           -fx-border-radius: 8;"/>

            <Button text="📅  Calendar" onAction="#openCalendar" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="🎓  My Grades" onAction="#openGpa" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="⏱  Study Timer" onAction="#openStudyTimer" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Region prefHeight="1" style="-fx-background-color: #581c87;"/>

        <Button text="↪  Log Out" onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                       -fx-font-size: 13px; -fx-padding: 14 14;
                       -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox HBox.hgrow="ALWAYS" spacing="16" style="-fx-padding: 24; -fx-background-color: #ede7f6;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 14 20; -fx-border-color: #d8b4fe;
                     -fx-border-radius: 12; -fx-border-width: 1;">
            <HBox spacing="0" alignment="CENTER_LEFT">
                <Region prefWidth="5" prefHeight="44"
                        style="-fx-background-color: #3b0764; -fx-background-radius: 3;"/>
                <VBox spacing="3" style="-fx-padding: 0 0 0 12;">
                    <Label text="My Tasks"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                    <Label fx:id="welcomeLabel" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="📋  TaskMaster"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #581c87;
                          -fx-background-color: #f5f0ff; -fx-background-radius: 8;
                          -fx-padding: 6 14;"/>
        </HBox>

        <!-- Add Task Card -->
        <VBox spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 18; -fx-border-color: #d8b4fe;
                     -fx-border-radius: 12; -fx-border-width: 1;">

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="➕" style="-fx-font-size: 14px;"/>
                <Label text="Add New Task"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="titleField" promptText="Task Title" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #f5f0ff; -fx-text-fill: #3b0764;
                                  -fx-prompt-text-fill: #111111; -fx-padding: 9 12;
                                  -fx-background-radius: 8; -fx-font-size: 12px;
                                  -fx-border-color: #e9d5ff; -fx-border-radius: 8; -fx-border-width: 1;"/>
                <TextField fx:id="courseField" promptText="Course" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #f5f0ff; -fx-text-fill: #3b0764;
                                  -fx-prompt-text-fill: #111111; -fx-padding: 9 12;
                                  -fx-background-radius: 8; -fx-font-size: 12px;
                                  -fx-border-color: #e9d5ff; -fx-border-radius: 8; -fx-border-width: 1;"/>
                <TextField fx:id="deadlineField" promptText="Deadline (YYYY-MM-DD)" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #f5f0ff; -fx-text-fill: #3b0764;
                                  -fx-prompt-text-fill: #111111; -fx-padding: 9 12;
                                  -fx-background-radius: 8; -fx-font-size: 12px;
                                  -fx-border-color: #e9d5ff; -fx-border-radius: 8; -fx-border-width: 1;"/>
            </HBox>

            <HBox spacing="10">
                <ComboBox fx:id="priorityBox" promptText="Priority"
                          HBox.hgrow="ALWAYS" maxWidth="Infinity"
                          style="-fx-background-color: #f5f0ff; -fx-padding: 4;
                                 -fx-background-radius: 8; -fx-border-color: #e9d5ff;
                                 -fx-border-radius: 8; -fx-border-width: 1;"/>

                <ComboBox fx:id="typeBox" promptText="Task Type"
                          HBox.hgrow="ALWAYS" maxWidth="Infinity"
                          style="-fx-background-color: #f5f0ff; -fx-padding: 4;
                                 -fx-background-radius: 8; -fx-border-color: #e9d5ff;
                                 -fx-border-radius: 8; -fx-border-width: 1;"/>

                <TextField fx:id="notesField" promptText="Notes (optional)" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #f5f0ff; -fx-text-fill: #3b0764;
                                  -fx-prompt-text-fill: #111111; -fx-padding: 9 12;
                                  -fx-background-radius: 8; -fx-font-size: 12px;
                                  -fx-border-color: #e9d5ff; -fx-border-radius: 8; -fx-border-width: 1;"/>

                <Button text="➕  Add Task" onAction="#handleAddTask"
                        style="-fx-background-color: #a855f7; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button text="💾  Save Edit" onAction="#handleSaveEdit"
                        style="-fx-background-color: #581c87; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

            <Label fx:id="messageLabel" text=""
                   style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Task Table Card -->
        <VBox spacing="12" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 18; -fx-border-color: #d8b4fe;
                     -fx-border-radius: 12; -fx-border-width: 1;">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📋" style="-fx-font-size: 14px;"/>
                <Label text="Task List"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Filter:" style="-fx-font-size: 12px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
                <ComboBox fx:id="filterBox" promptText="All Tasks" onAction="#handleFilter"
                          style="-fx-font-size: 12px; -fx-padding: 4 8;
                                 -fx-background-color: #f5f0ff; -fx-background-radius: 8;
                                 -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
            </HBox>

            <TableView fx:id="taskTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #f5f0ff; -fx-background-radius: 8;
                              -fx-border-color: #e9d5ff; -fx-border-radius: 8; -fx-border-width: 1;">
                <columns>
                    <TableColumn fx:id="titleColumn"    text="Title"    prefWidth="155"/>
                    <TableColumn fx:id="courseColumn"   text="Course"   prefWidth="100"/>
                    <TableColumn fx:id="deadlineColumn" text="Deadline" prefWidth="100"/>
                    <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="75"/>
                    <TableColumn fx:id="statusColumn"   text="Status"   prefWidth="100"/>
                    <TableColumn fx:id="notesColumn"    text="Notes"    prefWidth="148"/>
                    <TableColumn fx:id="typeColumn"     text="Type"     prefWidth="100"/>
                </columns>
            </TableView>

            <!-- Action Buttons -->
            <HBox spacing="10">
                <Button text="✅  Mark Complete" onAction="#handleMarkComplete"
                        style="-fx-background-color: #3b0764; -fx-text-fill: white;
                               -fx-padding: 9 16; -fx-background-radius: 8;
                               -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Button text="🔄  In Progress" onAction="#handleMarkInProgress"
                        style="-fx-background-color: #581c87; -fx-text-fill: white;
                               -fx-padding: 9 16; -fx-background-radius: 8;
                               -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Button text="✏️  Edit Task" onAction="#handleEditTask"
                        style="-fx-background-color: #a855f7; -fx-text-fill: white;
                               -fx-padding: 9 16; -fx-background-radius: 8;
                               -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Button text="🗑️  Delete Task" onAction="#handleDeleteTask"
                        style="-fx-background-color: #AA336A; -fx-text-fill: white;
                               -fx-padding: 9 16; -fx-background-radius: 8;
                               -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
