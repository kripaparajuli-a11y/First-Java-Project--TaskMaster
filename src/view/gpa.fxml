<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.GpaController"
      spacing="10"
      style="-fx-background-color: #f0f4f8; -fx-padding: 20;">

    <!-- Header -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15; -fx-background-radius: 8;">
        <Button fx:id="backButton"
                text="← Back"
                onAction="#goBack"
                style="-fx-background-color: #3498db;
                       -fx-text-fill: white;
                       -fx-padding: 6 14;
                       -fx-background-radius: 5;
                       -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="GPA Calculator"
               style="-fx-text-fill: white;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="TaskMaster"
               style="-fx-text-fill: #3498db;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>
    </HBox>

    <!-- GPA Display -->
    <VBox alignment="CENTER"
          style="-fx-background-color: white;
                 -fx-padding: 15;
                 -fx-background-radius: 8;">
        <Label fx:id="gpaLabel"
               text="No grades added yet."
               style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #7f8c8d;"/>
    </VBox>

    <!-- Add Grade Form -->
    <VBox spacing="8"
          style="-fx-background-color: white;
                 -fx-padding: 15;
                 -fx-background-radius: 8;">
        <Label text="Add / Update Grade"
               style="-fx-font-size: 15px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2c3e50;"/>
        <HBox spacing="10">
            <TextField fx:id="courseNameField"
                       promptText="Course Name (e.g. CIS096)"
                       style="-fx-padding: 8;"
                       HBox.hgrow="ALWAYS"/>
            <TextField fx:id="percentageField"
                       promptText="Percentage (0-100)"
                       style="-fx-padding: 8;"
                       HBox.hgrow="ALWAYS"/>
            <Button text="Add Grade"
                    onAction="#handleAddGrade"
                    style="-fx-background-color: #27ae60;
                           -fx-text-fill: white;
                           -fx-padding: 8 20;
                           -fx-background-radius: 5;
                           -fx-cursor: hand;"/>
        </HBox>
        <Label fx:id="messageLabel"
               text=""
               style="-fx-font-size: 12px;"/>
    </VBox>

    <!-- GPA Table -->
    <VBox spacing="8" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white;
                 -fx-padding: 15;
                 -fx-background-radius: 8;">
        <Label text="My Grades"
               style="-fx-font-size: 15px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2c3e50;"/>
        <TableView fx:id="gpaTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="courseColumn"
                             text="Course"
                             prefWidth="250"/>
                <TableColumn fx:id="percentageColumn"
                             text="Percentage"
                             prefWidth="150"/>
                <TableColumn fx:id="gpaColumn"
                             text="GPA Points"
                             prefWidth="150"/>
            </columns>
        </TableView>
        <HBox spacing="10">
            <Button text="Delete Grade"
                    onAction="#handleDeleteGrade"
                    style="-fx-background-color: #e74c3c;
                           -fx-text-fill: white;
                           -fx-padding: 8 15;
                           -fx-background-radius: 5;
                           -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- GPA Scale Reference -->
    <VBox style="-fx-background-color: white;
                 -fx-padding: 15;
                 -fx-background-radius: 8;">
        <Label text="GPA Scale Reference"
               style="-fx-font-size: 13px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2c3e50;"/>
        <Label text="90-100% = 4.0   |   80-89% = 3.7   |   70-79% = 3.0   |   60-69% = 2.7   |   50-59% = 2.0   |   Below 50% = 0.0"
               style="-fx-font-size: 11px;
                      -fx-text-fill: #7f8c8d;"/>
    </VBox>

</VBox>