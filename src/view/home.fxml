<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.DashboardController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #f0f0f5;">

    <!-- LEFT SIDEBAR -->
    <VBox prefWidth="220"
          style="-fx-background-color: #1a1a2e; -fx-padding: 0;">

        <!-- Profile Section -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-padding: 24 16 20 16;
                     -fx-border-color: transparent transparent #2d2d44 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="˙ᵕ˙" style="-fx-font-size: 36px; -fx-text-fill: white;"/>
            <Label fx:id="studentNameLabel" text="Student"
                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label fx:id="studentEmailLabel" text="@email"
                   style="-fx-text-fill: #a855f7; -fx-font-size: 10px;"
                   wrapText="true" maxWidth="180" alignment="CENTER"/>
        </VBox>

        <!-- Nav Buttons — Home is active on this page -->
        <VBox spacing="2" style="-fx-padding: 12 10;">

            <!-- Home active -->
            <Button text="🏠  Home" onAction="#goHome" maxWidth="Infinity"
                    style="-fx-background-color: #2d2d44; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;
                           -fx-border-color: #a855f7; -fx-border-width: 0 0 0 3;
                           -fx-border-radius: 8;"/>

            <Button text="✅  My Tasks" onAction="#openTasks" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #b0b0c0;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="📅  Calendar" onAction="#openCalendar" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #b0b0c0;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="🎓  My Grades" onAction="#openGpa" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #b0b0c0;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="⏱  Study Timer" onAction="#openStudyTimer" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #b0b0c0;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Thin divider line above logout -->
        <Region prefHeight="1" style="-fx-background-color: #2d2d44;"/>

        <!-- Logout button -->
        <Button text="↪  Log Out" onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #b0b0c0;
                       -fx-font-size: 13px; -fx-padding: 14 14;
                       -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
    </VBox>

    <!-- MAIN CONTENT — HOME -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="20"
          style="-fx-padding: 40; -fx-background-color: #f0f0f5;">

        <Label text="👋" style="-fx-font-size: 60px;"/>

        <HBox spacing="0" alignment="CENTER_LEFT">
            <Region prefWidth="5" prefHeight="60"
                style="-fx-background-color: #a855f7; -fx-background-radius: 3;"/>
            <VBox spacing="4" style="-fx-padding: 0 0 0 12;">
                <Label text="Welcome"
                    style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label fx:id="welcomeLabel" text="Student!"
                    style="-fx-font-size: 14px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <Label text="What would you like to do today?"
               style="-fx-font-size: 14px; -fx-text-fill: #9e9e9e;"/>

        <!-- Quick Action Cards -->
        <HBox spacing="20" alignment="CENTER">

            <VBox alignment="CENTER" spacing="10" prefWidth="180" prefHeight="140"
                  onMouseClicked="#openTasks"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-cursor: hand;
                         -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-border-width: 0.5;">
                <Label text="✅" style="-fx-font-size: 30px;"/>
                <Label text="My Tasks"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="View and manage tasks"
                       style="-fx-font-size: 11px; -fx-text-fill: #9e9e9e;"
                       wrapText="true" alignment="CENTER"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" prefWidth="180" prefHeight="140"
                  onMouseClicked="#openGpa"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-cursor: hand;
                         -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-border-width: 0.5;">
                <Label text="🎓" style="-fx-font-size: 30px;"/>
                <Label text="My Grades"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Track your grades"
                       style="-fx-font-size: 11px; -fx-text-fill: #9e9e9e;"
                       wrapText="true" alignment="CENTER"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" prefWidth="180" prefHeight="140"
                  onMouseClicked="#openStudyTimer"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-cursor: hand;
                         -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-border-width: 0.5;">
                <Label text="⏱" style="-fx-font-size: 30px;"/>
                <Label text="Study Timer"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Track study sessions"
                       style="-fx-font-size: 11px; -fx-text-fill: #9e9e9e;"
                       wrapText="true" alignment="CENTER"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" prefWidth="180" prefHeight="140"
                  onMouseClicked="#openCalendar"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-cursor: hand;
                         -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-border-width: 0.5;">
                <Label text="📅" style="-fx-font-size: 30px;"/>
                <Label text="Calendar"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Coming soon"
                       style="-fx-font-size: 11px; -fx-text-fill: #9e9e9e;"
                       wrapText="true" alignment="CENTER"/>
            </VBox>

        </HBox>
    </VBox>
</HBox>
