<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.CalendarController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #ede7f6;">

    <!-- LEFT SIDEBAR -->
    <VBox prefWidth="230"
          style="-fx-background-color: #1a1a2e; -fx-padding: 0;">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 24 16 20 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="📚" style="-fx-font-size: 32px;"/>
            <Label text="TaskMaster"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Profile -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 20 16 20 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <StackPane>
                <Circle radius="28" style="-fx-fill: #a855f7;"/>
                <Label fx:id="avatarInitial" text="S"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="studentNameLabel" text="Student"
                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label fx:id="studentEmailLabel" text=""
                   style="-fx-text-fill: #c084fc; -fx-font-size: 11px;"
                   wrapText="true" maxWidth="190" alignment="CENTER"/>
        </VBox>

        <!-- Nav Buttons -->
        <VBox spacing="4" style="-fx-padding: 16 12;">
            <Button text="🏠  Home" onAction="#goHome" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="✅  My Tasks" onAction="#openTasks" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <!-- Calendar active -->
            <Button text="📅  Calendar" onAction="#openCalendar" maxWidth="Infinity"
                    style="-fx-background-color: #581c87; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold;
                           -fx-border-color: #a855f7; -fx-border-width: 0 0 0 3;
                           -fx-border-radius: 8;"/>
            <Button text="🎓  My Grades" onAction="#openGpa" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="⏱  Study Timer" onAction="#openStudyTimer" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Region prefHeight="1" style="-fx-background-color: #581c87;"/>
        <Button text="↪  Log Out" onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                       -fx-font-size: 13px; -fx-padding: 14 14;
                       -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox HBox.hgrow="ALWAYS" spacing="10"
          style="-fx-padding: 16; -fx-background-color: #ede7f6;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 12 20; -fx-border-color: #d8b4fe;
                     -fx-border-radius: 12; -fx-border-width: 1;">
            <HBox spacing="0" alignment="CENTER_LEFT">
                <Region prefWidth="5" prefHeight="40"
                        style="-fx-background-color: #3b0764; -fx-background-radius: 3;"/>
                <VBox spacing="2" style="-fx-padding: 0 0 0 12;">
                    <Label text="Calendar"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                    <Label fx:id="welcomeLabel" text=""
                           style="-fx-font-size: 11px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Calendar (left) + Kanban (right) -->
        <HBox spacing="12" VBox.vgrow="ALWAYS">

            <!-- ── CALENDAR PANEL ── -->
            <VBox spacing="0" prefWidth="400" minWidth="370"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-color: #d8b4fe; -fx-border-radius: 12; -fx-border-width: 1;">

                <!-- Month Navigation -->
                <HBox alignment="CENTER" spacing="14"
                      style="-fx-padding: 10 14; -fx-border-color: #e9d5ff; -fx-border-width: 0 0 1 0;">
                    <Button text="◀" onAction="#previousMonth"
                            style="-fx-background-color: #f5f0ff; -fx-text-fill: #a855f7;
                                   -fx-font-weight: bold; -fx-padding: 5 12;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                    <Label fx:id="monthYearLabel" text="Month Year"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-text-fill: #3b0764; -fx-min-width: 150px;"
                           alignment="CENTER"/>
                    <Button text="▶" onAction="#nextMonth"
                            style="-fx-background-color: #f5f0ff; -fx-text-fill: #a855f7;
                                   -fx-font-weight: bold; -fx-padding: 5 12;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                </HBox>

                <!-- Legend -->
                <HBox alignment="CENTER" spacing="14"
                      style="-fx-padding: 6 14; -fx-border-color: #e9d5ff; -fx-border-width: 0 0 1 0;">
                    <HBox spacing="4" alignment="CENTER">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: #a855f7; -fx-background-radius: 3;"/>
                        <Label text="Today" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                    </HBox>
                    <HBox spacing="4" alignment="CENTER">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: #f3e5f5; -fx-border-color: #ce93d8;
                                       -fx-border-radius: 3; -fx-border-width: 1;"/>
                        <Label text="Has Tasks" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                    </HBox>
                    <HBox spacing="4" alignment="CENTER">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                       -fx-border-radius: 3; -fx-border-width: 1;"/>
                        <Label text="No Tasks" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                    </HBox>
                </HBox>

                <!-- Calendar Grid -->
                <GridPane fx:id="calendarGrid"
                          hgap="3" vgap="3"
                          style="-fx-padding: 8;"
                          maxWidth="Infinity">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                        <ColumnConstraints percentWidth="14.28" fillWidth="true"/>
                    </columnConstraints>
                </GridPane>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Inline Day Detail -->
                <VBox spacing="3"
                      style="-fx-background-color: #f5f0ff; -fx-padding: 10 14;
                             -fx-border-color: #d8b4fe; -fx-border-width: 1 0 0 0;
                             -fx-background-radius: 0 0 12 12;">
                    <Label fx:id="dayDetailLabel" text="Click a day to see tasks"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #581c87;"/>
                    <Label fx:id="dayTasksLabel" text=""
                           style="-fx-font-size: 11px; -fx-text-fill: #3b0764;"
                           wrapText="true"/>
                </VBox>
            </VBox>

            <!-- ── KANBAN PANEL (horizontal rows) ── -->
            <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" spacing="8">

                <Label text="📋  Task Board"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>

                <!-- Not Started -->
                <VBox spacing="6" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-padding: 10 12; -fx-border-color: #d8b4fe;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: #9e9e9e; -fx-background-radius: 50;"/>
                        <Label text="Not Started"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    </HBox>
                    <ScrollPane fitToHeight="true" prefHeight="80" VBox.vgrow="ALWAYS"
                                hbarPolicy="NEVER" vbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-background: transparent;">
                        <HBox fx:id="notStartedRow" spacing="8" style="-fx-padding: 2;"/>
                    </ScrollPane>
                </VBox>

                <!-- In Progress -->
                <VBox spacing="6" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-padding: 10 12; -fx-border-color: #d8b4fe;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: #f59e0b; -fx-background-radius: 50;"/>
                        <Label text="In Progress"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    </HBox>
                    <ScrollPane fitToHeight="true" prefHeight="80" VBox.vgrow="ALWAYS"
                                hbarPolicy="NEVER" vbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-background: transparent;">
                        <HBox fx:id="inProgressRow" spacing="8" style="-fx-padding: 2;"/>
                    </ScrollPane>
                </VBox>

                <!-- Completed -->
                <VBox spacing="6" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-padding: 10 12; -fx-border-color: #d8b4fe;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: #22c55e; -fx-background-radius: 50;"/>
                        <Label text="Completed"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    </HBox>
                    <ScrollPane fitToHeight="true" prefHeight="80" VBox.vgrow="ALWAYS"
                                hbarPolicy="NEVER" vbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-background: transparent;">
                        <HBox fx:id="completedRow" spacing="8" style="-fx-padding: 2;"/>
                    </ScrollPane>
                </VBox>

                <!-- Overdue -->
                <VBox spacing="6" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-padding: 10 12; -fx-border-color: #d8b4fe;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Region prefWidth="10" prefHeight="10"
                                style="-fx-background-color: #ef4444; -fx-background-radius: 50;"/>
                        <Label text="Overdue"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                    </HBox>
                    <ScrollPane fitToHeight="true" prefHeight="80" VBox.vgrow="ALWAYS"
                                hbarPolicy="NEVER" vbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-background: transparent;">
                        <HBox fx:id="overdueRow" spacing="8" style="-fx-padding: 2;"/>
                    </ScrollPane>
                </VBox>

            </VBox>
        </HBox>
    </VBox>
</HBox>
