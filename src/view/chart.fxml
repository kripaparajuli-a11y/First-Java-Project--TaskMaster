<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ChartController"
      spacing="10"
      style="-fx-background-color: #f0f4f8; -fx-padding: 20;">

    <!-- Header -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15; -fx-background-radius: 8;">
        <Button fx:id="backButton"
                text="← Back"
                onAction="#goBack"
                style="-fx-background-color: #3498db;
                       -fx-text-fill: white;
                       -fx-padding: 6 14;
                       -fx-background-radius: 5;
                       -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Workload Charts"
               style="-fx-text-fill: white;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="TaskMaster"
               style="-fx-text-fill: #3498db;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>
    </HBox>

    <!-- Total Tasks Label -->
    <VBox alignment="CENTER"
          style="-fx-background-color: white;
                 -fx-padding: 10;
                 -fx-background-radius: 8;">
        <Label fx:id="totalLabel"
               text="Total Tasks: 0"
               style="-fx-font-size: 16px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2c3e50;"/>
    </VBox>

    <!-- Charts Side by Side -->
    <HBox spacing="10" VBox.vgrow="ALWAYS">

        <!-- Pie Chart -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color: white;
                     -fx-padding: 15;
                     -fx-background-radius: 8;">
            <PieChart fx:id="statusPieChart"
                      VBox.vgrow="ALWAYS"
                      prefHeight="350"
                      labelsVisible="true"/>
        </VBox>

        <!-- Bar Chart -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color: white;
                     -fx-padding: 15;
                     -fx-background-radius: 8;">
            <BarChart fx:id="priorityBarChart"
                      VBox.vgrow="ALWAYS"
                      prefHeight="350">
                <xAxis>
                    <CategoryAxis fx:id="xAxis"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="yAxis"/>
                </yAxis>
            </BarChart>
        </VBox>

    </HBox>

</VBox>