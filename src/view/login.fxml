<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      prefWidth="1000" prefHeight="620"
      style="-fx-background-color: #ede7f6;">

    <HBox alignment="CENTER"
          HBox.hgrow="ALWAYS"
          style="-fx-padding: 40;">

        <HBox style="-fx-background-color: #d8b4fe;
                     -fx-background-radius: 18;
                     -fx-border-radius: 18;
                     -fx-border-color: #a855f7;
                     -fx-border-width: 2.5;"
              prefWidth="860" prefHeight="480">

            <!-- LEFT: Illustration -->
            <StackPane prefWidth="480"
                       style="-fx-background-color: #f5f0ff;
                              -fx-background-radius: 18 0 0 18;">
                <ImageView fitWidth="340" fitHeight="340"
                           preserveRatio="true">
                    <image>
                        <Image url="file:///C:/Users/LENOVO/OneDrive/Desktop/TaskMaster/bin/assets/students.png"/>
                    </image>
                </ImageView>
            </StackPane>

            <!-- RIGHT: Form -->
            <VBox alignment="CENTER"
                  spacing="14"
                  prefWidth="380"
                  style="-fx-background-color: #c084fc;
                         -fx-padding: 36 28;
                         -fx-background-radius: 0 18 18 0;">

                <Label text="Task Master"
                       style="-fx-font-size: 30px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #3b0764;
                              -fx-font-family: 'Georgia';"/>

                <Label text="SIGN IN TO YOUR ACCOUNT"
                       style="-fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #581c87;"/>

                <VBox style="-fx-background-color: white;
                             -fx-background-radius: 14;
                             -fx-padding: 20 18;"
                      spacing="10" maxWidth="320">

                    <VBox spacing="4">
                        <Label text="Email:"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #4a4a4a;"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   maxWidth="Infinity"
                                   style="-fx-background-color: #e9d5ff;
                                          -fx-background-radius: 8;
                                          -fx-border-color: transparent;
                                          -fx-padding: 9 12;
                                          -fx-font-size: 13px;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Password:"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #4a4a4a;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Enter your password"
                                       maxWidth="Infinity"
                                       style="-fx-background-color: #e9d5ff;
                                              -fx-background-radius: 8;
                                              -fx-border-color: transparent;
                                              -fx-padding: 9 12;
                                              -fx-font-size: 13px;"/>
                    </VBox>

                    <Label fx:id="messageLabel"
                           text=""
                           wrapText="true"
                           maxWidth="300"
                           alignment="CENTER"
                           style="-fx-font-size: 11px;"/>

                    <Button text="Log In"
                            fx:id="loginButton"
                            onAction="#handleLogin"
                            maxWidth="Infinity"
                            style="-fx-background-color: #a855f7;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 10;
                                   -fx-padding: 11 0;
                                   -fx-font-family: 'Georgia';
                                   -fx-cursor: hand;"/>
                </VBox>

                <Button fx:id="registerButton"
                        text="Don't have an account? Register"
                        onAction="#goToRegister"
                        style="-fx-background-color: transparent;
                               -fx-border-color: transparent;
                               -fx-text-fill: #3b0764;
                               -fx-font-size: 11px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-underline: true;"/>
            </VBox>
        </HBox>
    </HBox>
</HBox>
