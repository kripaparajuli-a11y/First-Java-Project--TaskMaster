<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      alignment="CENTER"
      spacing="15"
      style="-fx-background-color: #f0f4f8; -fx-padding: 50;">

    <Label text="TaskMaster"
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Student Assignment Manager"
           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <VBox spacing="10"
          style="-fx-background-color: white;
                 -fx-padding: 30;
                 -fx-background-radius: 10;
                 -fx-effect: dropshadow(gaussian, #cccccc, 10, 0, 0, 2);">

        <Label text="Email:" style="-fx-font-size: 13px;"/>
        <TextField fx:id="emailField"
                   promptText="Enter your email"
                   style="-fx-font-size: 13px; -fx-padding: 8;"/>

        <Label text="Password:" style="-fx-font-size: 13px;"/>
        <PasswordField fx:id="passwordField"
                       promptText="Enter your password"
                       style="-fx-font-size: 13px; -fx-padding: 8;"/>

        <Button fx:id="loginButton"
                text="Login"
                onAction="#handleLogin"
                style="-fx-background-color: #3498db;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-padding: 10 20;
                       -fx-background-radius: 5;
                       -fx-cursor: hand;"
                maxWidth="Infinity"/>

        <Label fx:id="messageLabel"
               text=""
               style="-fx-font-size: 12px;"
               alignment="CENTER"
               maxWidth="Infinity"/>

        <Separator/>

        <Button fx:id="registerButton"
                text="Don't have an account? Register here"
                onAction="#goToRegister"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #27ae60;
                       -fx-font-size: 12px;
                       -fx-cursor: hand;
                       -fx-underline: true;"
                maxWidth="Infinity"/>
    </VBox>
</VBox>