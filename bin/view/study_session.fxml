<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.StudySessionController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #ede7f6;">

    <!-- LEFT SIDEBAR -->
    <VBox prefWidth="230"
          style="-fx-background-color: #1a1a2e; -fx-padding: 0;">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 24 16 20 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="📚" style="-fx-font-size: 32px;"/>
            <Label text="TaskMaster"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Profile -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 20 16 20 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <StackPane>
                <Circle radius="28" style="-fx-fill: #a855f7;"/>
                <Label fx:id="avatarInitial" text="S"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="studentNameLabel" text="Student"
                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label fx:id="studentEmailLabel" text=""
                   style="-fx-text-fill: #c084fc; -fx-font-size: 11px;"
                   wrapText="true" maxWidth="190" alignment="CENTER"/>
        </VBox>

        <!-- Nav Buttons -->
        <VBox spacing="4" style="-fx-padding: 16 12;">
            <Button text="🏠  Home" onAction="#goHome" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="✅  My Tasks" onAction="#openTasks" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="📅  Calendar" onAction="#openCalendar" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="🎓  My Grades" onAction="#openGpa" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <!-- Study Timer active -->
            <Button text="⏱  Study Timer" onAction="#openStudyTimer" maxWidth="Infinity"
                    style="-fx-background-color: #581c87; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold;
                           -fx-border-color: #a855f7; -fx-border-width: 0 0 0 3;
                           -fx-border-radius: 8;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Region prefHeight="1" style="-fx-background-color: #581c87;"/>
        <Button text="↪  Log Out" onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                       -fx-font-size: 13px; -fx-padding: 14 14;
                       -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox HBox.hgrow="ALWAYS" spacing="12"
          style="-fx-padding: 20; -fx-background-color: #ede7f6;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 12 20; -fx-border-color: #d8b4fe;
                     -fx-border-radius: 12; -fx-border-width: 1;">
            <Region prefWidth="5" prefHeight="40"
                    style="-fx-background-color: #3b0764; -fx-background-radius: 3;"/>
            <VBox spacing="2" style="-fx-padding: 0 0 0 12;">
                <Label text="Study Timer"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                <Label fx:id="welcomeLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="totalStudyLabel" text="Total today: 0 min"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #581c87;
                          -fx-background-color: #f5f0ff; -fx-background-radius: 8;
                          -fx-padding: 6 16;"/>
        </HBox>

        <!-- Timer + History side by side -->
        <HBox spacing="12" VBox.vgrow="ALWAYS">

            <!-- LEFT: Timer Panel -->
            <VBox spacing="12" prefWidth="420" minWidth="380"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-border-color: #d8b4fe;
                         -fx-border-radius: 12; -fx-border-width: 1;">

                <!-- Mode tabs -->
                <HBox spacing="0" alignment="CENTER"
                      style="-fx-background-color: #f5f0ff; -fx-background-radius: 10;
                             -fx-border-color: #e9d5ff; -fx-border-radius: 10; -fx-border-width: 1;">
                    <Button fx:id="stopwatchTab" text="⏱  Stopwatch"
                            onAction="#switchStopwatch" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 10 0; -fx-background-radius: 10 0 0 10;
                                   -fx-cursor: hand;"/>
                    <Button fx:id="countdownTab" text="⏳  Countdown"
                            onAction="#switchCountdown" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-text-fill: #581c87;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 10 0; -fx-background-radius: 0 10 10 0;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- Mode label -->
                <Label fx:id="modeLabel" text="⏱  Stopwatch"
                       alignment="CENTER" maxWidth="Infinity"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #581c87;"/>

                <!-- Clock display -->
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: #f5f0ff; -fx-background-radius: 16;
                             -fx-padding: 30 20; -fx-border-color: #d8b4fe;
                             -fx-border-radius: 16; -fx-border-width: 2;">
                    <Label fx:id="timerLabel" text="00:00"
                           style="-fx-font-size: 64px; -fx-font-weight: bold;
                                  -fx-text-fill: #3b0764; -fx-font-family: 'Courier New';"/>
                    <Label fx:id="timerSubLabel" text="Elapsed time"
                           style="-fx-font-size: 12px; -fx-text-fill: #a855f7;"/>
                </VBox>

                <!-- Countdown input -->
                <HBox fx:id="countdownInputBox" spacing="8" alignment="CENTER"
                      visible="false" managed="false">
                    <Label text="Set time:"
                           style="-fx-font-size: 12px; -fx-text-fill: #581c87; -fx-font-weight: bold;"/>
                    <TextField fx:id="countdownMinField" promptText="00" prefWidth="70"
                               style="-fx-background-color: #f5f0ff; -fx-text-fill: #3b0764;
                                      -fx-padding: 6 10; -fx-background-radius: 8;
                                      -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-font-size: 13px; -fx-alignment: CENTER;"/>
                    <Label text="min" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                    <TextField fx:id="countdownSecField" promptText="00" prefWidth="70"
                               style="-fx-background-color: #f5f0ff; -fx-text-fill: #3b0764;
                                      -fx-padding: 6 10; -fx-background-radius: 8;
                                      -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;
                                      -fx-font-size: 13px; -fx-alignment: CENTER;"/>
                    <Label text="sec" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                    <Button text="Set" onAction="#handleSetCountdown"
                            style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-padding: 6 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <!-- Control buttons -->
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="startStopButton" text="▶  Start"
                            onAction="#handleStartStop"
                            style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-padding: 12 28; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <Button text="↺  Reset" onAction="#handleReset"
                            style="-fx-background-color: #f5f0ff; -fx-text-fill: #581c87;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-padding: 12 28; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-border-color: #d8b4fe; -fx-border-width: 1;"/>
                </HBox>

                <!-- Save session -->
                <Region VBox.vgrow="ALWAYS"/>
                <VBox fx:id="saveSessionBox" spacing="8"
                      style="-fx-background-color: #f5f0ff; -fx-background-radius: 10;
                             -fx-padding: 12; -fx-border-color: #e9d5ff;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <Label text="💾  Save Session"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #581c87;"/>
                    <TextField fx:id="notesField" promptText="Notes (optional, e.g. 'Chapter 3 review')"
                               style="-fx-background-color: white; -fx-text-fill: #3b0764;
                                      -fx-prompt-text-fill: #aaa; -fx-padding: 8 10;
                                      -fx-background-radius: 8; -fx-font-size: 12px;
                                      -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                    <Button text="💾  Save to History" onAction="#handleSaveSession"
                            maxWidth="Infinity"
                            style="-fx-background-color: #3b0764; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: bold;
                                   -fx-padding: 9 0; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Label fx:id="saveMessageLabel" text=""
                           style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>
            </VBox>

            <!-- RIGHT: Session History -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16; -fx-border-color: #d8b4fe;
                         -fx-border-radius: 12; -fx-border-width: 1;">

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📋" style="-fx-font-size: 14px;"/>
                    <Label text="Session History"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🗑️  Delete" onAction="#handleDeleteSession"
                            style="-fx-background-color: #AA336A; -fx-text-fill: white;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-padding: 6 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #f5f0ff; -fx-background-radius: 8;
                                  -fx-border-color: #e9d5ff; -fx-border-radius: 8;
                                  -fx-border-width: 1;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="hDateColumn"     text="Date"      prefWidth="110"/>
                        <TableColumn fx:id="hTypeColumn"     text="Type"      prefWidth="110"/>
                        <TableColumn fx:id="hDurationColumn" text="Duration"  prefWidth="110"/>
                        <TableColumn fx:id="hNotesColumn"    text="Notes"     prefWidth="200"/>
                    </columns>
                </TableView>

            </VBox>
        </HBox>
    </VBox>
</HBox>
