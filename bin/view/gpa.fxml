<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.GpaController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #ede7f6;">

    <!-- LEFT SIDEBAR -->
    <VBox prefWidth="230"
          style="-fx-background-color: #1a1a2e; -fx-padding: 0;">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 24 16 20 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="📚" style="-fx-font-size: 32px;"/>
            <Label text="TaskMaster"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Profile -->
        <VBox alignment="CENTER" spacing="4"
              style="-fx-padding: 20 16 20 16;
                     -fx-border-color: transparent transparent #581c87 transparent;
                     -fx-border-width: 0 0 1 0;">
            <StackPane>
                <Circle radius="28" style="-fx-fill: #a855f7;"/>
                <Label fx:id="avatarInitial" text="S"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="studentNameLabel" text="Student"
                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label fx:id="studentEmailLabel" text=""
                   style="-fx-text-fill: #c084fc; -fx-font-size: 11px;"
                   wrapText="true" maxWidth="190" alignment="CENTER"/>
        </VBox>

        <!-- Nav Buttons -->
        <VBox spacing="4" style="-fx-padding: 16 12;">
            <Button text="🏠  Home" onAction="#goHome" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="✅  My Tasks" onAction="#openTasks" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="📅  Calendar" onAction="#openCalendar" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <!-- My Grades active -->
            <Button text="🎓  My Grades" onAction="#openGpa" maxWidth="Infinity"
                    style="-fx-background-color: #581c87; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold;
                           -fx-border-color: #a855f7; -fx-border-width: 0 0 0 3;
                           -fx-border-radius: 8;"/>
            <Button text="⏱  Study Timer" onAction="#openStudyTimer" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                           -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Region prefHeight="1" style="-fx-background-color: #581c87;"/>
        <Button text="↪  Log Out" onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #d8b4fe;
                       -fx-font-size: 13px; -fx-padding: 14 14;
                       -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
    </VBox>

    <!-- MAIN CONTENT -->
    <VBox HBox.hgrow="ALWAYS" spacing="12"
          style="-fx-padding: 20; -fx-background-color: #ede7f6;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 12 20; -fx-border-color: #d8b4fe;
                     -fx-border-radius: 12; -fx-border-width: 1;">
            <Region prefWidth="5" prefHeight="40"
                    style="-fx-background-color: #3b0764; -fx-background-radius: 3;"/>
            <VBox spacing="2" style="-fx-padding: 0 0 0 12;">
                <Label text="My Grades"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                <Label fx:id="welcomeLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="overallLabel" text="No grades yet"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #581c87;
                          -fx-background-color: #f5f0ff; -fx-background-radius: 8;
                          -fx-padding: 6 16;"/>
        </HBox>

        <!-- Two columns -->
        <HBox spacing="12" VBox.vgrow="ALWAYS">

            <!-- LEFT: Course Panel -->
            <VBox spacing="10" prefWidth="320" minWidth="280"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16; -fx-border-color: #d8b4fe;
                         -fx-border-radius: 12; -fx-border-width: 1;">

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📚" style="-fx-font-size: 14px;"/>
                    <Label text="Courses"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                </HBox>

                <VBox spacing="8"
                      style="-fx-background-color: #f5f0ff; -fx-background-radius: 10;
                             -fx-padding: 12; -fx-border-color: #e9d5ff;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <Label text="Add New Course"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #581c87;"/>
                    <TextField fx:id="courseNameField" promptText="Course Name (e.g. CIS096)"
                               style="-fx-background-color: white; -fx-text-fill: #3b0764;
                                      -fx-prompt-text-fill: #aaa; -fx-padding: 8 10;
                                      -fx-background-radius: 8; -fx-font-size: 12px;
                                      -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                    <TextField fx:id="semesterField" promptText="Semester (e.g. Fall 2025)"
                               style="-fx-background-color: white; -fx-text-fill: #3b0764;
                                      -fx-prompt-text-fill: #aaa; -fx-padding: 8 10;
                                      -fx-background-radius: 8; -fx-font-size: 12px;
                                      -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                    <HBox spacing="8">
                        <Button text="➕  Add Course" onAction="#handleAddCourse"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                       -fx-font-size: 11px; -fx-font-weight: bold;
                                       -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="🗑️ Delete" onAction="#handleDeleteCourse"
                                style="-fx-background-color: #AA336A; -fx-text-fill: white;
                                       -fx-font-size: 11px; -fx-font-weight: bold;
                                       -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <Label fx:id="courseMessageLabel" text=""
                       style="-fx-font-size: 11px; -fx-font-weight: bold;"/>

                <Label text="Select a course to add marks:"
                       style="-fx-font-size: 11px; -fx-text-fill: #888;"/>

                <ListView fx:id="courseListView" VBox.vgrow="ALWAYS"
                          onMouseClicked="#handleCourseSelected"
                          style="-fx-background-color: #faf5ff;
                                 -fx-border-color: #e9d5ff; -fx-border-radius: 8;
                                 -fx-border-width: 1; -fx-background-radius: 8;"/>

                <!-- Grade Scale -->
                <VBox spacing="3"
                      style="-fx-background-color: #f5f0ff; -fx-background-radius: 8;
                             -fx-padding: 10; -fx-border-color: #e9d5ff;
                             -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="📊 Grade Scale"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                    <Label text="90-100% → A+     80-89% → A"
                           style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
                    <Label text="70-79% → B+      60-69% → B"
                           style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
                    <Label text="50-59% → C+      40-49% → C"
                           style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
                    <Label text="30-39% → D       Below 30% → F"
                           style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
            </VBox>

            <!-- RIGHT: Assessment Panel -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16; -fx-border-color: #d8b4fe;
                         -fx-border-radius: 12; -fx-border-width: 1;">

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="✏️" style="-fx-font-size: 14px;"/>
                    <Label fx:id="selectedCourseLabel" text="Select a course first"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b0764;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label fx:id="currentGradeLabel" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                        <Label fx:id="projectedGradeLabel" text=""
                               style="-fx-font-size: 12px; -fx-text-fill: #a855f7; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <Region prefHeight="1" style="-fx-background-color: #e9d5ff;"/>

                <!-- Add / Edit Assessment form -->
                <VBox spacing="8"
                      style="-fx-background-color: #f5f0ff; -fx-background-radius: 10;
                             -fx-padding: 12; -fx-border-color: #e9d5ff;
                             -fx-border-radius: 10; -fx-border-width: 1;">
                    <Label fx:id="formTitleLabel" text="Add Assessment (Assignment / Exam / Quiz...)"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #581c87;"/>
                    <HBox spacing="8">
                        <TextField fx:id="assessmentNameField" promptText="Name (e.g. Midterm Exam)"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: white; -fx-text-fill: #3b0764;
                                          -fx-prompt-text-fill: #aaa; -fx-padding: 8 10;
                                          -fx-background-radius: 8; -fx-font-size: 12px;
                                          -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                        <TextField fx:id="weightField" promptText="Weight %" prefWidth="90"
                                   style="-fx-background-color: white; -fx-text-fill: #3b0764;
                                          -fx-prompt-text-fill: #aaa; -fx-padding: 8 10;
                                          -fx-background-radius: 8; -fx-font-size: 12px;
                                          -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                        <TextField fx:id="scoreField" promptText="Score %" prefWidth="90"
                                   style="-fx-background-color: white; -fx-text-fill: #3b0764;
                                          -fx-prompt-text-fill: #aaa; -fx-padding: 8 10;
                                          -fx-background-radius: 8; -fx-font-size: 12px;
                                          -fx-border-color: #d8b4fe; -fx-border-radius: 8; -fx-border-width: 1;"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button fx:id="addEditButton" text="➕  Add Assessment"
                                onAction="#handleAddOrEditAssessment"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                       -fx-font-size: 11px; -fx-font-weight: bold;
                                       -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✏️  Edit" onAction="#handleEditAssessment"
                                style="-fx-background-color: #581c87; -fx-text-fill: white;
                                       -fx-font-size: 11px; -fx-font-weight: bold;
                                       -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="🗑️  Delete" onAction="#handleDeleteAssessment"
                                style="-fx-background-color: #AA336A; -fx-text-fill: white;
                                       -fx-font-size: 11px; -fx-font-weight: bold;
                                       -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                    <Label fx:id="assessmentMessageLabel" text=""
                           style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>

                <Label fx:id="weightWarningLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #b45309; -fx-font-weight: bold;"/>

                <!-- Assessment Table -->
                <TableView fx:id="assessmentTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #f5f0ff; -fx-background-radius: 8;
                                  -fx-border-color: #e9d5ff; -fx-border-radius: 8;
                                  -fx-border-width: 1;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="aNameColumn"    text="Assessment"  prefWidth="210"/>
                        <TableColumn fx:id="aWeightColumn"  text="Weight %"    prefWidth="100"/>
                        <TableColumn fx:id="aScoreColumn"   text="Score %"     prefWidth="100"/>
                        <TableColumn fx:id="aGradeColumn"   text="Grade"       prefWidth="90"/>
                        <TableColumn fx:id="aContribColumn" text="Contributes" prefWidth="110"/>
                    </columns>
                </TableView>

            </VBox>
        </HBox>
    </VBox>
</HBox>
